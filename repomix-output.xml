RUN useradd -m -u 1001 myappuser
USER myappuser
WORKDIR /home/myappuser/app

COPY --from=builder /app/package.json /app/package-lock.json* ./
RUN npm ci --omit=dev

COPY --from=builder --chown=myappuser:myappuser /app/dist ./dist
